# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...
# Service role key — server-side only; never exposed to the browser
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# ─── Cloudflare R2 ───────────────────────────────────────────────────────────
R2_ACCOUNT_ID=abc123def456
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=sab-trip-media
# Public URL — either the r2.dev domain or your custom domain
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxx.r2.dev

# ─── Cloudmailin ─────────────────────────────────────────────────────────────
# The @cloudmailin.net address Cloudmailin assigns to your target
CLOUDMAILIN_TARGET_ADDRESS=abc123@cloudmailin.net
# Comma-separated list of sender email addresses allowed to create posts
ALLOWED_SENDERS=you@gmail.com,other@gmail.com
# Map sender emails to display names stored on each post (email=Name pairs, comma-separated)
SENDER_NAMES=you@gmail.com=Your Name,other@gmail.com=Other Name

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app
# Random secret to protect the /api/revalidate endpoint
REVALIDATE_SECRET=change_me_to_a_long_random_string

# ─── Auth ────────────────────────────────────────────────────────────────────
# Password required to view the site (splash page)
SITE_PASSWORD=change_me_site_password
# Password for admin access (enables edit/delete)
ADMIN_PASSWORD=change_me_admin_password
